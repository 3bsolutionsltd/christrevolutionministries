{
  "name": "crministries",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:admin": "next dev --config next.config.admin.js",
    "build": "next build",
    "build:admin": "next build --config next.config.admin.js",
    "build:staging": "node scripts/generate-static-data.js && cross-env NODE_ENV=production NEXT_PUBLIC_ENVIRONMENT=staging next build",
    "build:production": "node scripts/generate-static-data.js && cross-env NODE_ENV=production NEXT_PUBLIC_ENVIRONMENT=production next build",
    "start": "next start",
    "start:admin": "next start --config next.config.admin.js",
    "lint": "next lint",
    "export": "next build",
    "deploy": "npm run export",
    "deploy:staging": "npm run build:staging",
    "deploy:production": "npm run build:production",
    "security:check": "powershell -File ./scripts/security-check.ps1",
    "security:csp": "node scripts/analyze-csp.js",
    "security:monitor": "npm run security:check && npm run security:csp"
  },
  "dependencies": {
    "next": "15.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20.5.9",
    "@types/react": "^18.2.24",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "8.48.0",
    "eslint-config-next": "^15.4.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.4.2"
  }
}
