# Environment variables for Christ Revolution Ministries
# Copy this file to .env.local and fill in your actual values

# Development URL (use HTTP for local development)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Production URL (for OAuth webhook)
PRODUCTION_BASE_URL=https://yourdomain.com

# Development settings
NODE_ENV=development

# GitHub OAuth Configuration
# Create a GitHub OAuth App at: https://github.com/settings/applications/new
# Authorization callback URL should be: https://yourdomain.com/admin-oauth-login.html
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# GitHub Webhook Secret (optional but recommended for security)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Session Security (generate random strings)
SESSION_SECRET=your_random_session_secret_minimum_32_characters
JWT_SECRET=your_random_jwt_secret_minimum_32_characters