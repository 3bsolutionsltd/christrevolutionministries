# Staging Environment Configuration
NEXT_PUBLIC_ENVIRONMENT=staging
NEXT_PUBLIC_SITE_URL=https://dev.christrevolutionministries.org
NEXT_PUBLIC_API_URL=https://dev.christrevolutionministries.org/api

# Analytics and Tracking (use test/dev keys for staging)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
